# .env.cloud - Variables de Entorno para Google Cloud Run
# Copia este archivo y configura estos valores en Cloud Run

# ===== REQUERIDO =====
# API key de OpenRouter con MiniMax minimax-01 (https://openrouter.ai/keys)
OPENROUTER_API_KEY=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

# ===== OPCIONAL (DESHABILITADO) =====
# API key de Google AI Studio - NO se usa en esta configuración
# GOOGLE_API_KEY=

# ===== CONFIGURACIÓN DEL SERVIDOR =====
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=production

# ===== LÍMITES =====
MAX_MESSAGE_LENGTH=5000
MAX_RESPONSE_LENGTH=10000

# ===== NOTA =====
# Estas variables se configuran directamente en Cloud Run
# NO necesitas crear un archivo .env en producción
# Solo usa este archivo como referencia de qué configurar
